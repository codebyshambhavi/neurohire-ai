# ---------------------------------------------------------------------------
# NeuroHire AI — Backend environment configuration
# Copy this file to `.env` and fill in real values before running the app.
# ---------------------------------------------------------------------------

# Environment: development | staging | production
ENVIRONMENT=development

# App metadata
PROJECT_NAME="NeuroHire AI"
API_V1_PREFIX=/api/v1

# --- Database ---
# SQLite is fine for local development. Swap for Postgres in staging/prod, e.g.:
# DATABASE_URL=postgresql+psycopg2://neurohire:password@localhost:5432/neurohire
DATABASE_URL=sqlite:///./neurohire.db

# --- Auth / JWT ---
# Generate a real secret with: openssl rand -hex 32
SECRET_KEY=replace-this-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- CORS ---
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- ML Engine ---
ML_ENGINE_URL=http://127.0.0.1:8001
ML_ENGINE_TIMEOUT_SECONDS=30
